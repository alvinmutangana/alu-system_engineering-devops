#!/usr/bin/env bash
# Installs and configures Nginx to serve 'Holberton School for the win!'

# Exit on error
set -e

# Update package lists
apt-get update -y

# Install Nginx
apt-get install -y nginx

# Write the required message into the default index.html
echo "Holberton School for the win!" > /var/www/html/index.html

# Restart and enable Nginx
systemctl restart nginx
systemctl enable nginx
